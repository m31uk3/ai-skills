  "template_grok_convo": {
    "id": "grok_convo",
    "name": "Grok Conversation",
    "behavior": "create",
    "noteNameFormat": "{{url|replace:\".*conversation=\",\"\"|kebab|replace:\"/--+/g\":\"-\"|replace:\"/^-+|-+$/g\":\"\"|slice:0,80}}",
    "path": "GenAI/Grok/chats",
    "noteContentFormat": "---\ntitle: \"{{title}}\"\nid: \"{{url|replace:\".*conversation=\",\"\"}}\"\nsource: \"{{url|replace:\"/[?&]utm_[^&]*/g\":\"\"}}\"\nsurface: \"{% if url contains 'x.com' %}x.com{% else %}grok.com{% endif %}\"\ncaptured: \"{{date}}\"\nword_count: \"{{words}}\"\nstatus: \"to-be-reviewed\"\ntype: \"grok-conversation\"\ntags: [grok, chat]\n---\n\n# {{title}}\n\nSource: [{{url|replace:\"/[?&]utm_[^&]*/g\":\"\"}}]({{url|replace:\"/[?&]utm_[^&]*/g\":\"\"}})\nSurface: {% if url contains 'x.com' %}x.com{% else %}grok.com{% endif %}\n\n## User Prompts\n\n{{content}}\n\n## Grok Replies\n\n{{content}}\n\n## Grok X Sources\n\n{{content}}\n\n## Grok Web Sources\n\n{{content}}\n\n## Grok Thinking / Reasoning\n\n{{content}}\n\n## Tool Calls & Hooks\n\n{{content}}\n\n---\n\n## Clean Defuddled Version (reference)\n\n{{content}}\n\n---\n\nCaptured [[journals/{{date|date:\"YYYY\"}}/{{date|date:\"MMMM\"}}/{{date|date:\"DD-MMM-YYYY\"}}|{{date|date:\"DD-MMM-YYYY\"}}]]\n\n[Source]({{url|replace:\"/[?&]utm_[^&]*/g\":\"\"}})",
    "properties": [
      {
        "id": "grok_title",
        "name": "title",
        "value": "{{title}}",
        "type": "text"
      },
      {
        "id": "grok_id",
        "name": "id",
        "value": "{{url|replace:\".*conversation=\",\"\"}}",
        "type": "text"
      },
      {
        "id": "grok_source",
        "name": "source",
        "value": "{{url|replace:\"/[?&]utm_[^&]*/g\":\"\"}}",
        "type": "text"
      },
      {
        "id": "grok_surface",
        "name": "surface",
        "value": "{% if url contains 'x.com' %}x.com{% else %}grok.com{% endif %}",
        "type": "text"
      },
      {
        "id": "grok_created",
        "name": "created",
        "value": "{{date}}",
        "type": "date"
      },
      {
        "id": "grok_word_count",
        "name": "word_count",
        "value": "{{words}}",
        "type": "text"
      },
      {
        "id": "grok_status",
        "name": "status",
        "value": "to-be-reviewed",
        "type": "text"
      },
      {
        "id": "grok_type",
        "name": "type",
        "value": "grok-conversation",
        "type": "text"
      },
      {
        "id": "grok_tags",
        "name": "tags",
        "value": "grok,chat",
        "type": "multitext"
      }
    ],
    "triggers": [
      "grok.com",
      "x.com/i/grok",
      "x.com/i/grok?conversation="
    ],
    "context": ""
  }
}